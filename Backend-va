from flask import Flask, request, jsonif
import pandas as pd
from sklearn.cluster import KMeans

app = Flask(__name__)

# Load dataset
data = pd.read_csv("c:\Users\Vaidehi Kishor\OneDrive\Desktop\Documents\GitHub\Pixel4\crime_dataset_india.csv")

coords = data[['latitude','longitude']]

# Train AI clustering model
model = KMeans(n_clusters=5)
data['danger_zone'] = model.fit_predict(coords)

@app.route("/crime_zones")

def crime_zones():

    zones = data[['latitude','longitude','danger_zone']].to_dict(orient='records')
    
    return jsonify(zones)

